<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>StyleStore — Управление магазином одежды</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #F2EFEA;
    color: #1C1B17;
    font-size: 14px;
    line-height: 1.45;
    height: 100vh;
    overflow: hidden;
  }

  :root {
    --bg-body: #F2EFEA;
    --card-bg: #FFFFFF;
    --border-light: #E6E1D9;
    --border-med: #D4CEC4;
    --text-primary: #1C1B17;
    --text-secondary: #6B665C;
    --text-muted: #A09A90;
    --accent: #1F4D3C;
    --accent-soft: #E2F0EA;
    --accent-text: #13412F;
    --danger: #BB2E3E;
    --danger-bg: #FCE9EC;
    --warning: #C75E0E;
    --warning-bg: #FFF0E3;
    --info: #2B4F8C;
    --info-bg: #E3EDF7;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.04), 0 2px 6px rgba(0,0,0,0.03);
    --shadow-md: 0 8px 20px rgba(0,0,0,0.08);
    --radius-md: 12px;
    --radius-sm: 8px;
  }

  .app {
    display: flex;
    height: 100%;
    width: 100%;
  }

  .sidebar {
    width: 260px;
    background: var(--accent);
    color: white;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    overflow-y: auto;
  }

  .sidebar-header {
    padding: 26px 20px 20px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    background: rgba(255,255,255,0.15);
    width: 38px;
    height: 38px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .logo-text {
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.2px;
  }

  .logo-sub {
    font-size: 11px;
    opacity: 0.65;
    margin-top: 2px;
  }

  .nav {
    padding: 20px 12px;
    flex: 1;
  }

  .nav-group {
    margin-bottom: 24px;
  }

  .nav-label {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    padding: 0 12px 8px 12px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    margin: 2px 0;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    transition: all 0.15s;
  }

  .nav-item i {
    width: 20px;
    font-size: 14px;
    text-align: center;
  }

  .nav-item:hover {
    background: rgba(255,255,255,0.1);
    color: white;
  }

  .nav-item.active {
    background: rgba(255,255,255,0.2);
    color: white;
    font-weight: 500;
  }

  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .top-bar {
    background: var(--card-bg);
    border-bottom: 1px solid var(--border-light);
    padding: 12px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .title-section {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .title-section h1 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
  }

  .record-badge {
    background: #F0EDE8;
    padding: 4px 12px;
    border-radius: 40px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .search {
    position: relative;
  }

  .search i {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 13px;
  }

  .search input {
    padding: 8px 12px 8px 36px;
    border: 1px solid var(--border-light);
    border-radius: 28px;
    background: #F9F8F6;
    font-family: inherit;
    font-size: 13px;
    width: 240px;
    transition: all 0.2s;
    outline: none;
  }

  .search input:focus {
    border-color: var(--accent);
    background: white;
    box-shadow: 0 0 0 2px rgba(31,77,60,0.1);
  }

  .btn-primary {
    background: var(--accent);
    border: none;
    padding: 8px 18px;
    border-radius: 30px;
    font-weight: 600;
    font-size: 13px;
    color: white;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: #0f3a2c;
    transform: translateY(-1px);
  }

  .content-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 24px 28px;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 28px;
  }

  .stat-card {
    background: var(--card-bg);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 16px 18px;
    box-shadow: var(--shadow-sm);
  }

  .stat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .stat-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .stat-icon {
    width: 34px;
    height: 34px;
    background: var(--accent-soft);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-text);
    font-size: 16px;
  }

  .stat-number {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .table-wrapper {
    background: var(--card-bg);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: auto;
    box-shadow: var(--shadow-sm);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 680px;
  }

  .data-table th {
    text-align: left;
    padding: 14px 16px;
    background: #F9F8F6;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
  }

  .data-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-light);
    font-size: 13px;
    color: #262421;
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table tr:hover td {
    background-color: #FCFAF8;
  }

  .badge {
    display: inline-flex;
    padding: 4px 10px;
    border-radius: 40px;
    font-size: 11px;
    font-weight: 600;
    background: #EEEEEA;
    color: #3d3a34;
  }

  .badge-success { background: var(--accent-soft); color: var(--accent-text); }
  .badge-danger { background: var(--danger-bg); color: var(--danger); }
  .badge-warning { background: var(--warning-bg); color: var(--warning); }
  .badge-info { background: var(--info-bg); color: var(--info); }

  .price-cell {
    font-family: 'DM Mono', monospace;
    font-weight: 500;
  }

  .qty-low { color: var(--danger); font-weight: 700; }
  .qty-mid { color: var(--warning); font-weight: 600; }

  .action-icons {
    display: flex;
    gap: 8px;
  }

  .icon-btn {
    background: transparent;
    border: none;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-secondary);
    transition: 0.1s;
  }

  .icon-btn:hover {
    background: #F0EDE8;
    color: var(--text-primary);
  }

  .icon-btn.danger:hover {
    background: var(--danger-bg);
    color: var(--danger);
  }

  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(28, 27, 23, 0.5);
    backdrop-filter: blur(3px);
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  .modal-overlay.open {
    display: flex;
  }

  .modal-container {
    background: white;
    width: 520px;
    max-width: 92vw;
    border-radius: 24px;
    box-shadow: var(--shadow-md);
    animation: fadeUp 0.2s ease;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px);}
    to { opacity: 1; transform: translateY(0);}
  }

  .modal-header {
    padding: 18px 22px;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .modal-header h3 {
    font-size: 17px;
    font-weight: 700;
  }

  .modal-close {
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    width: 32px;
    height: 32px;
    border-radius: 10px;
  }

  .modal-body {
    padding: 20px 22px;
    max-height: 60vh;
    overflow-y: auto;
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-group label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 5px;
    color: #47433c;
  }

  .form-group input, .form-group select, .form-group textarea {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    background: #FCFCFB;
    font-family: inherit;
    font-size: 13px;
    transition: 0.15s;
    outline: none;
  }

  .form-group input:focus, .form-group select:focus {
    border-color: var(--accent);
    background: white;
    box-shadow: 0 0 0 2px rgba(31,77,60,0.1);
  }

  .row-2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .modal-footer {
    padding: 14px 22px;
    border-top: 1px solid var(--border-light);
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    background: #FCFAF8;
    border-radius: 0 0 24px 24px;
  }

  .btn-secondary {
    background: transparent;
    border: 1px solid var(--border-med);
    padding: 8px 18px;
    border-radius: 30px;
    font-weight: 500;
    cursor: pointer;
  }

  .btn-save {
    background: var(--accent);
    border: none;
    padding: 8px 22px;
    border-radius: 30px;
    color: white;
    font-weight: 600;
    cursor: pointer;
  }

  .empty-message {
    text-align: center;
    padding: 56px 20px;
    color: var(--text-muted);
  }

  .toast-stack {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1100;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .toast {
    background: #1C1B17;
    color: white;
    padding: 10px 20px;
    border-radius: 48px;
    font-size: 13px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: var(--shadow-md);
    animation: slideIn 0.2s ease;
  }

  .toast.success { background: var(--accent); }
  .toast.error { background: var(--danger); }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(20px);}
    to { opacity: 1; transform: translateX(0);}
  }
</style>
</head>
